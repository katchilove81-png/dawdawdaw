--=========================================================================
-- FETCH CHAT (always re-fetches and re-renders on change)
--=========================================================================
local function parseReply(text)
    local replyTag, replyPreview, rest = text:match("^replying to %[(.-)%]: (.-)%s*|%s*(.+)$")
    if replyTag then
        return { tag = replyTag, preview = replyPreview }, rest
    end
    return nil, text
end

local function fetchChat()
    -- Capture and immediately clear forceRefresh so it never gets stuck
    local wasForced = forceRefresh
    forceRefresh = false

    local response = nil

    -- Always try executor HTTP + GitHub API first (bypasses CDN cache)
    pcall(function()
        local httpFunc = nil
        pcall(function() if syn then httpFunc = syn.request end end)
        if not httpFunc then pcall(function() httpFunc = request end) end
        if not httpFunc then pcall(function() httpFunc = http_request end) end
        if not httpFunc then pcall(function() httpFunc = http and http.request end) end
        if not httpFunc then pcall(function() httpFunc = fluxus and fluxus.request end) end
        if httpFunc and typeof(httpFunc) == "function" then
            local resp = httpFunc({
                Url    = CHAT_API_URL .. "?t=" .. tostring(tick()),
                Method = "GET",
                Headers = {
                    ["Accept"]     = "application/vnd.github.v3.raw",
                    ["User-Agent"] = "RobloxChat",
                    ["Cache-Control"] = "no-cache",
                },
            })
            if resp and resp.Body and #resp.Body > 5 then
                response = resp.Body
            end
        end
    end)

    -- Fallback: use game:HttpGet (may be CDN-cached for ~5 min)
    if not response then
        local success, result = pcall(function()
            return game:HttpGet(CHAT_URL .. "?t=" .. tostring(tick()))
        end)
        if success then
            response = result
        else
            statusLabel.Text = "Connection failed"
            return
        end
    end

    if not response then
        statusLabel.Text = "No response"
        return
    end

    -- Only re-render if the raw data actually changed
    local responseHash = tostring(#response) .. response:sub(1, 80) .. response:sub(-40)
    if not wasForced and responseHash == lastFetchHash then
        return -- data identical, skip re-render
    end
    lastFetchHash = responseHash

    local decoded
    local ok = pcall(function()
        decoded = HttpService:JSONDecode(response)
    end)

    if not ok or not decoded or not decoded.messages then
        statusLabel.Text = "Invalid data"
        return
    end

    local messages = decoded.messages
    local count = #messages
    local prevCount = #renderedMessages

    clearMessages()

    local endIdx = math.min(count, MAX_DISPLAY)
    for i = endIdx, 1, -1 do
        local msg   = messages[i]
        local uname = msg.username or "Unknown"
        local text  = msg.message or msg.text or ""
        local tstmp = msg.timestamp or ""
        local isOwn = (uname == displayTag)

        local replyInfo, cleanText = parseReply(text)

        local isMention = false
        if not isOwn then
            if replyInfo and replyInfo.tag == displayTag then
                isMention = true
            end
            if text:find(displayTag, 1, true) then
                isMention = true
            end
        end

        createMessageBubble(uname, cleanText, tstmp, isOwn, isMention, replyInfo)
    end

    -- Unread badge
    if not panelOpen and count > prevCount and prevCount > 0 then
        local newCount = count - prevCount
        unreadBadge.Visible = true
        unreadLabel.Text = tostring(math.min(newCount, 99))
    end

    scrollToBottom()
    statusLabel.Text = os.date("%H:%M:%S")
end

--=========================================================================
-- SEND MESSAGE (with 20s cooldown, NO client-side message)
--=========================================================================
local function sendMessage()
    local text = inputBox.Text
    if not text or text:match("^%s*$") then return end

    -- Cooldown check
    local now = tick()
    local remaining = SEND_COOLDOWN - (now - lastSendTime)
    if remaining > 0 then
        statusLabel.Text = string.format("Wait %ds", math.ceil(remaining))
        return
    end

    inputBox.Text = ""
    lastSendTime = tick()

    -- Build message body
    local body = text
    if replyingTo then
        local preview = string.sub(replyingTo.message, 1, 50)
        body = "replying to [" .. replyingTo.tag .. "]: " .. preview .. " | " .. text
    end

    -- Clear reply state
    hideReplyBanner()

    -- Start cooldown visual
    task.spawn(function()
        local endTime = lastSendTime + SEND_COOLDOWN
        sendBtn.Text = ""
        cooldownLabel.Visible = true
        sendBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 78)

        while true do
            local left = math.ceil(endTime - tick())
            if left <= 0 then break end
            cooldownLabel.Text = tostring(left)
            task.wait(0.5)
        end

        cooldownLabel.Visible = false
        cooldownLabel.Text = ""
        sendBtn.Text = ">"
        sendBtn.BackgroundColor3 = ACCENT
    end)

    -- Validate URL is set
    if SEND_URL == "" or SEND_URL == "YOUR_PIPEDREAM_WEBHOOK_URL_HERE" then
        statusLabel.Text = "No webhook URL!"
        return
    end

    -- Find a working HTTP request function (executor-specific)
    local httpRequest = nil
    local httpName = "none"

    local tryFuncs = {
        { function() return syn and syn.request end,    "syn.request" },
        { function() return request end,                "request" },
        { function() return http_request end,           "http_request" },
        { function() return http and http.request end,  "http.request" },
        { function() return fluxus and fluxus.request end, "fluxus.request" },
    }

    for _, entry in ipairs(tryFuncs) do
        local ok, fn = pcall(entry[1])
        if ok and fn and typeof(fn) == "function" then
            httpRequest = fn
            httpName = entry[2]
            break
        end
    end

    if not httpRequest then
        statusLabel.Text = "No HTTP func!"
        return
    end


    -- Send to Pipedream webhook (Pipedream handles GitHub API)
    local payload = HttpService:JSONEncode({
        username  = displayTag,
        message   = body,
        timestamp = os.date("%H:%M"),
    })

    local sendOk, sendErr = pcall(function()
        local resp = httpRequest({
            Url     = SEND_URL,
            Method  = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
                ["Accept"]       = "application/json",
            },
            Body    = payload,
        })

        if resp then

            if resp.StatusCode and resp.StatusCode >= 400 then
                error("Server returned status " .. tostring(resp.StatusCode) .. ": " .. tostring(resp.Body):sub(1, 200))
            end
        else
            print("No response object returned (may still have sent)")
        end
    end)

    if not sendOk then
        statusLabel.Text = "Send failed"
    else
        statusLabel.Text = "Sent!"
        -- Force an immediate refresh to pick up the new message from server
        forceRefresh = true
        task.delay(1.5, fetchChat)
        task.delay(4, fetchChat)
        task.delay(8, fetchChat)
    end
end

sendBtn.MouseButton1Click:Connect(sendMessage)

inputBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then sendMessage() end
end)

--=========================================================================
-- LOGIN FLOW
--=========================================================================
local loggedIn = false

local function completeLogin(name)
    local clean = name:gsub("^%s+", ""):gsub("%s+$", "")
    if #clean < 1 then return end

    displayName = clean
    displayTag  = clean .. "#" .. previewNum
    saveCredentials()

    tween(loginOverlay, { BackgroundTransparency = 1 }, 0.3)
    tween(loginCard, { Position = UDim2.new(0.5, 0, 0.5, 40) }, 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    task.delay(0.35, function()
        loginOverlay.Visible = false
        loginOverlay:Destroy()
    end)

    bubbleButton.Visible = true
    task.defer(function() snapToEdge(bubbleButton) end)

    loggedIn = true

    -- Start auto-refresh loop
    task.spawn(function()
        while true do
            if loggedIn then
                pcall(fetchChat)
            end
            task.wait(REFRESH_INTERVAL)
        end
    end)

end

loginBtn.MouseButton1Click:Connect(function()
    completeLogin(loginInput.Text)
end)

loginInput.FocusLost:Connect(function(enterPressed)
    if enterPressed then completeLogin(loginInput.Text) end
end)

-- Auto-login if credentials are saved on device
if savedCredentials and savedCredentials.displayName and savedCredentials.displayTag then
    displayName = savedCredentials.displayName
    displayTag  = savedCredentials.displayTag

    if savedCredentials.theme and THEMES[savedCredentials.theme] then
        applyTheme(savedCredentials.theme)
    end

    loginOverlay.Visible = false
    task.defer(function()
        if loginOverlay.Parent then loginOverlay:Destroy() end
    end)

    bubbleButton.Visible = true
    task.defer(function() snapToEdge(bubbleButton) end)

    loggedIn = true

    task.spawn(function()
        while true do
            if loggedIn then
                pcall(fetchChat)
            end
            task.wait(REFRESH_INTERVAL)
        end
    end)

else
    -- Entrance animation
    loginCard.Position = UDim2.new(0.5, 0, 0.5, 30)
    loginCard.BackgroundTransparency = 1
    task.defer(function()
        tween(loginCard, {
            Position = UDim2.new(0.5, 0, 0.5, 0),
            BackgroundTransparency = 0,
        }, 0.5)
    end)

end
