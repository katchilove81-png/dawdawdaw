local function positionPanelNearBubble()
    local vp  = workspace.CurrentCamera.ViewportSize
    local bp  = bubbleButton.AbsolutePosition
    local bs  = bubbleButton.AbsoluteSize
    local bcx = bp.X + bs.X / 2
    local onRight = bcx > vp.X / 2

    local px
    if onRight then px = bp.X - PANEL_WIDTH - 10
    else px = bp.X + bs.X + 10 end

    local py = math.clamp(bp.Y + bs.Y / 2 - PANEL_HEIGHT / 2, 8, vp.Y - PANEL_HEIGHT - 8)
    px = math.clamp(px, 8, vp.X - PANEL_WIDTH - 8)
    return UDim2.new(0, px, 0, py)
end

