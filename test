--=========================================================================
-- DRAG BUBBLE (snap to edge)
--=========================================================================
local dragging  = false
local dragStart = nil
local startPos  = nil
local hasMoved  = false

local function snapToEdge(frame)
    local vp = workspace.CurrentCamera.ViewportSize
    local ap = frame.AbsolutePosition
    local as = frame.AbsoluteSize
    local cx = ap.X + as.X / 2
    local cy = ap.Y + as.Y / 2

    local clampedY = math.clamp(cy, as.Y / 2 + 8, vp.Y - as.Y / 2 - 8)
    local targetX
    if cx < vp.X / 2 then
        targetX = 8
    else
        targetX = vp.X - as.X - 8
    end

    tween(frame, {
        Position = UDim2.new(0, targetX, 0, clampedY - as.Y / 2)
    }, 0.35, Enum.EasingStyle.Back)
end

bubbleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        hasMoved = false
        dragStart = input.Position
        startPos = bubbleButton.Position
    end
end)

bubbleButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
        snapToEdge(bubbleButton)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        if delta.Magnitude > 4 then hasMoved = true end
        bubbleButton.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

